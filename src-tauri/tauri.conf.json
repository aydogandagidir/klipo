{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Klipo",
  "version": "0.1.6",
  "identifier": "app.klipo.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Klipo",
        "width": 480,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "minimizable": false,
        "skipTaskbar": true,
        "visible": false,
        "shadow": true,
        "focus": true
      },
      {
        "label": "settings",
        "title": "Klipo Settings",
        "url": "/?window=settings",
        "width": 720,
        "height": 640,
        "minWidth": 600,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "minimizable": true,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/blobs/**",
          "$APPDATA/thumbs/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "publisher": "bluedev",
    "homepage": "https://bluedev.dev",
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Klipo by bluedev — clipboard manager.",
    "longDescription": "Klipo by bluedev — fast, private, keyboard-first clipboard manager with sensitive-content detection. Local-first SQLite storage; opt-in E2E sync arrives in v0.3. https://bluedev.dev/products/klipo"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/aydogandagidir/klipo/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxOTRFMzk1QkI1RkY5NEUKUldSTytWKzdsZU9VZ1pWaG1CTmEzZEFvdkk3YkRjUzZNQnhEUkVvN1M4SUlwSnErTTdJeWpmL08K"
    }
  }
}
